# ==============================================================================
# DRAWLAYOUTWEB ENVIRONMENT VARIABLES TEMPLATE
# Copy this file to .env.local and fill in your actual credentials.
# Do NOT commit your actual .env.local file to version control.
# ==============================================================================

# Database Connection (Supabase Transaction Pooler - Port 6543)
DATABASE_URL="postgres://postgres.[YOUR_PROJECT_REF]:[YOUR_PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?sslmode=require"

# Better Auth Configuration
# Generate a secure 32-byte hex key using: openssl rand -hex 32
BETTER_AUTH_SECRET="your_generated_random_32_byte_hex_string"
BETTER_AUTH_URL="http://localhost:3000"

# Gemini AI Endpoint Integration
# Get your free/tier key from https://aistudio.google.com
GEMINI_API_KEY="your_google_ai_studio_api_key"